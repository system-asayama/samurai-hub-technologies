<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex">
  <title><%= title %>｜管理</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/styles.css">
  <link rel="stylesheet" href="/assets/admin.css">
</head>
<body class="admin-body">
  <header class="admin-header">
    <div class="admin-header-inner">
      <a class="brand" href="/admin">
        <span class="brand-mark" aria-hidden="true">侍</span>
        <span class="brand-text"><strong>Samurai Hub</strong><small>Admin</small></span>
      </a>
      <nav class="admin-nav">
        <a href="/admin">ダッシュボード</a>
